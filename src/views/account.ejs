<%- include("partials/header") %>

<section class="account-shell">
  <aside class="account-sidebar">
    <p class="eyebrow">Account</p>
    <h1>會員中心</h1>
    <a class="<%= activeTab === 'orders' ? 'active' : '' %>" href="/account?tab=orders">我的訂單</a>
    <a class="<%= activeTab === 'profile' ? 'active' : '' %>" href="/account?tab=profile">個人資料</a>
    <a class="<%= activeTab === 'servers' ? 'active' : '' %>" href="/account?tab=servers">我的伺服器</a>
  </aside>

  <section class="account-content">
    <% if (activeTab === 'profile') { %>
      <div class="section-head compact">
        <div>
          <p class="eyebrow">Profile</p>
          <h2>個人資料</h2>
        </div>
      </div>
      <dl class="order-meta account-credentials">
        <dt>Email</dt><dd><%= user.email %></dd>
        <dt>密碼</dt>
        <dd class="password-stack">
          <span><%= passwordLabel %></span>
          <button class="button ghost password-modal-open" type="button">重設密碼</button>
        </dd>
      </dl>
      <% if (passwordError) { %>
        <div class="alert"><%= passwordError %></div>
      <% } %>
      <% if (passwordNotice) { %>
        <div class="notice"><%= passwordNotice %></div>
      <% } %>
      <% if (resetPassword) { %>
        <div class="notice">密碼已重設，可用於本店登入與 Panel 登入：<strong><%= resetPassword %></strong></div>
      <% } %>
      <div class="password-modal" aria-hidden="true">
        <div class="password-modal-backdrop" data-close-password-modal></div>
        <section class="password-modal-panel" role="dialog" aria-modal="true" aria-labelledby="password-modal-title">
          <button class="modal-close" type="button" data-close-password-modal aria-label="關閉">×</button>
          <p class="eyebrow">Password</p>
          <h3 id="password-modal-title">重設密碼</h3>
          <form class="password-reset-form" method="post" action="/account/password">
            <div class="password-mode-tabs">
              <label>
                <input type="radio" name="mode" value="custom" checked>
                <span>自訂密碼</span>
              </label>
              <label>
                <input type="radio" name="mode" value="random">
                <span>隨機密碼</span>
              </label>
            </div>

            <div class="password-mode-panel" data-mode-panel="custom">
              <label>
                新密碼
                <input type="password" name="customPassword" minlength="9" autocomplete="new-password">
              </label>
              <small>需大於 8 字元，且包含英文與數字。</small>
            </div>

            <div class="password-mode-panel hidden" data-mode-panel="random">
              <label>
                隨機長度 <strong data-password-length>16</strong>
                <input type="range" name="randomLength" min="12" max="32" value="16">
              </label>
              <input type="hidden" name="randomPassword">
              <code class="generated-password" data-generated-password></code>
            </div>

            <button class="button primary full" type="submit">更新密碼</button>
          </form>
        </section>
      </div>
    <% } %>

    <% if (activeTab === 'orders') { %>
      <div class="section-head compact">
        <div>
          <p class="eyebrow">Orders</p>
          <h2>我的訂單</h2>
        </div>
      </div>
      <% if (orders.length === 0) { %>
        <div class="empty-state">目前沒有訂單。</div>
      <% } else { %>
        <div class="order-list">
          <% orders.forEach((order) => { %>
            <a class="order-row" href="/orders/<%= order.id %>">
              <strong><%= order.product_name %></strong>
              <span><%= order.order_no %></span>
              <span>NT$ <%= order.amount %></span>
              <em><%= statusLabels[order.status] || order.status %></em>
            </a>
          <% }) %>
        </div>
      <% } %>
    <% } %>

    <% if (activeTab === 'servers') { %>
      <div class="section-head compact">
        <div>
          <p class="eyebrow">Servers</p>
          <h2>我的伺服器</h2>
        </div>
      </div>
      <% if (serverError) { %>
        <div class="alert"><%= serverError %></div>
      <% } %>
      <% if (serverNotice) { %>
        <div class="notice"><%= serverNotice %></div>
      <% } %>
      <% if (!servers || servers.length === 0) { %>
        <div class="empty-state">目前沒有已開通或開通中的伺服器。</div>
      <% } else { %>
        <div class="server-list">
          <% servers.forEach((server) => { %>
            <article class="server-row">
              <div class="server-row-main">
                <strong><%= server.name %></strong>
                <span><%= server.product_name || 'Server' %> / <%= server.order_no || '-' %></span>
                <span>Egg：<%= server.egg_name || server.egg_id || '-' %></span>
                <em class="<%= server.status === 'provisioned' ? 'ready' : 'installing' %>"><%= server.statusLabel %></em>
              </div>
              <form class="server-inline-form" method="post" action="/account/servers/<%= server.id %>/name">
                <label>
                  名稱
                  <input name="name" value="<%= server.name %>" maxlength="80" required>
                </label>
                <button class="button ghost" type="submit">改名</button>
              </form>
              <form class="server-inline-form" method="post" action="/account/servers/<%= server.id %>/egg">
                <label>
                  Egg
                  <select name="minecraftEggId" <%= minecraftEggs.length === 0 ? 'disabled' : '' %>>
                    <% minecraftEggs.forEach((egg) => { %>
                      <option value="<%= egg.id %>" <%= Number(server.egg_id) === Number(egg.id) ? 'selected' : '' %>><%= egg.name %></option>
                    <% }) %>
                  </select>
                </label>
                <button class="button ghost" type="submit" <%= minecraftEggs.length === 0 ? 'disabled' : '' %>>更改 Egg</button>
              </form>
              <a class="button primary" href="<%= server.panelUrl %>" target="_blank" rel="noreferrer">前往控制台</a>
            </article>
          <% }) %>
        </div>
      <% } %>
    <% } %>

  </section>
</section>

<script>
  const passwordModal = document.querySelector(".password-modal");
  const passwordOpen = document.querySelector(".password-modal-open");
  const passwordForm = document.querySelector(".password-reset-form");
  const modeRadios = document.querySelectorAll("input[name='mode']");
  const randomLength = document.querySelector("input[name='randomLength']");
  const randomPassword = document.querySelector("input[name='randomPassword']");
  const generatedPassword = document.querySelector("[data-generated-password]");
  const passwordLengthText = document.querySelector("[data-password-length]");
  const passwordChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()-_=+[]{};:,.?";

  const makePassword = (length) => {
    const required = ["A", "a", "0", "!"].map((seed, index) => {
      const groups = ["ABCDEFGHIJKLMNOPQRSTUVWXYZ", "abcdefghijklmnopqrstuvwxyz", "0123456789", "!@#$%^&*()-_=+[]{};:,.?"];
      const values = new Uint32Array(1);
      crypto.getRandomValues(values);
      return groups[index][values[0] % groups[index].length];
    });
    const values = new Uint32Array(Math.max(0, length - required.length));
    crypto.getRandomValues(values);
    const password = [...required, ...Array.from(values, (value) => passwordChars[value % passwordChars.length])];
    for (let index = password.length - 1; index > 0; index -= 1) {
      const values = new Uint32Array(1);
      crypto.getRandomValues(values);
      const target = values[0] % (index + 1);
      [password[index], password[target]] = [password[target], password[index]];
    }
    return password.join("");
  };

  const refreshRandomPassword = () => {
    if (!randomLength || !randomPassword || !generatedPassword) return;
    const length = Number(randomLength.value || 16);
    const password = makePassword(length);
    randomPassword.value = password;
    generatedPassword.textContent = password;
    if (passwordLengthText) passwordLengthText.textContent = String(length);
  };

  const setPasswordMode = () => {
    const mode = document.querySelector("input[name='mode']:checked")?.value || "custom";
    document.querySelectorAll("[data-mode-panel]").forEach((panel) => {
      panel.classList.toggle("hidden", panel.dataset.modePanel !== mode);
    });
    if (mode === "random") refreshRandomPassword();
  };

  passwordOpen?.addEventListener("click", () => {
    passwordModal?.classList.add("open");
    passwordModal?.setAttribute("aria-hidden", "false");
    refreshRandomPassword();
  });

  document.querySelectorAll("[data-close-password-modal]").forEach((element) => {
    element.addEventListener("click", () => {
      passwordModal?.classList.remove("open");
      passwordModal?.setAttribute("aria-hidden", "true");
    });
  });

  modeRadios.forEach((radio) => radio.addEventListener("change", setPasswordMode));
  randomLength?.addEventListener("input", refreshRandomPassword);
  passwordForm?.addEventListener("submit", () => {
    if (document.querySelector("input[name='mode']:checked")?.value === "random") refreshRandomPassword();
  });
  setPasswordMode();
</script>

<%- include("partials/footer") %>
