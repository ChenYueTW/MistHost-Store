<%- include("partials/header") %>

<section class="admin-shell">
  <aside class="admin-sidebar">
    <p class="eyebrow">Admin</p>
    <h1>管理員介面</h1>
    <a class="<%= activeTab === 'orders' ? 'active' : '' %>" href="/admin?tab=orders">訂單管理</a>
    <a class="<%= activeTab === 'coupons' ? 'active' : '' %>" href="/admin?tab=coupons">優惠代碼</a>
    <a class="<%= activeTab === 'fees' ? 'active' : '' %>" href="/admin?tab=fees">超商手續費</a>
    <a class="<%= activeTab === 'products' ? 'active' : '' %>" href="/admin?tab=products">商品管理</a>
    <a class="<%= activeTab === 'nodes' ? 'active' : '' %>" href="/admin?tab=nodes">設定節點</a>
    <a class="<%= activeTab === 'users' ? 'active' : '' %>" href="/admin?tab=users">使用者</a>
  </aside>

  <section class="admin-content">
    <% if (activeTab === 'orders') { %>
      <h2>管理訂單</h2>
      <div class="admin-table">
        <% orders.forEach((order) => { %>
          <div class="admin-order-row">
            <a class="admin-order-main" href="/orders/<%= order.id %>">
              <strong><%= order.order_name %></strong>
              <span><%= order.order_no %> · <%= order.customer_name %> / <%= order.email %></span>
            </a>
            <div class="admin-order-side">
              <strong>NT$ <%= order.amount %></strong>
              <details class="admin-status-menu">
                <summary><%= statusLabels[order.status] || order.status %></summary>
                <div>
                  <% orderStatuses.forEach((status) => { %>
                    <form method="post" action="/admin/orders/<%= order.id %>/status">
                      <input type="hidden" name="status" value="<%= status.value %>">
                      <button class="<%= order.status === status.value ? 'active' : '' %>" type="submit"><%= status.label %></button>
                    </form>
                  <% }) %>
                </div>
              </details>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (activeTab === 'coupons') { %>
      <h2>優惠代碼</h2>
      <form class="admin-form coupon-admin-form" method="post" action="/admin/coupons">
        <input class="coupon-code-input" name="code" placeholder="代碼" required>
        <select name="type">
          <option value="percent">百分比</option>
          <option value="fixed">固定金額</option>
        </select>
        <input name="value" placeholder="折扣" required>
        <button class="button primary" type="submit">新增/更新</button>
      </form>
      <div class="admin-table">
        <% coupons.forEach((coupon) => { %>
          <div class="coupon-admin-row">
            <strong><%= coupon.code %></strong>
            <span><%= coupon.type === 'percent' ? `${coupon.value}% 折扣` : `NT$ ${coupon.value} 折抵` %></span>
            <form method="post" action="/admin/coupons/<%= coupon.id %>/delete">
              <button class="admin-action-button danger" type="submit">刪除</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (activeTab === 'fees') { %>
      <h2>更改超商代碼手續費</h2>
      <form class="admin-form" method="post" action="/admin/fees">
        <label>
          超商代碼手續費
          <input type="number" name="cvsFee" min="0" value="<%= cvsFee %>" required>
        </label>
        <button class="button primary" type="submit">儲存</button>
      </form>
    <% } %>

    <% if (activeTab === 'products') { %>
      <h2>商品管理</h2>
      <form class="admin-form product-create-form" method="post" action="/admin/products">
        <div class="product-create-top">
          <input class="product-code-input" name="slug" placeholder="Product Code" pattern="[a-z0-9-]+" title="Use lowercase English letters, numbers, and hyphens." required>
          <input class="product-name-input" name="name" placeholder="Display Name" required>
          <select name="category" class="product-category-filter">
            <% productCategories.forEach((category) => { %>
              <option value="<%= category %>"><%= category %></option>
            <% }) %>
          </select>
        </div>
        <div class="product-create-bottom">
          <label class="unit-input"><input type="number" name="cpu" min="1" placeholder="核心" required><span>核心</span></label>
          <label class="unit-input"><input type="number" name="ram" min="1" placeholder="記憶體" required><span>GB</span></label>
          <label class="unit-input"><input type="number" name="storage" min="1" placeholder="儲存空間" required><span>GB</span></label>
          <input type="number" name="price" min="0" placeholder="價格" required>
          <button class="button primary" type="submit">新增商品</button>
        </div>
      </form>
      <div class="admin-table">
        <% products.forEach((product) => { %>
          <div class="product-admin-row" data-category="<%= product.category %>" <%= product.category !== productCategories[0] ? 'hidden' : '' %>>
            <div class="product-admin-heading">
              <strong><code><%= product.slug %></code></strong>
              <span><%= product.name %> / <%= product.category %> / <%= product.parsedSpecs.CPU || '-' %> / <%= product.parsedSpecs.Memory || '-' %> / <%= product.parsedSpecs.Disk || '-' %></span>
              <em><%= product.active ? '上架中' : '已下架' %></em>
            </div>
            <div class="product-admin-controls">
              <form method="post" action="/admin/products/<%= product.id %>/price">
                <label class="unit-input"><input type="number" name="cpu" min="1" value="<%= product.parsedSpecs.cpuValue %>" aria-label="CPU 核心"><span>核心</span></label>
                <label class="unit-input"><input type="number" name="ram" min="1" value="<%= product.parsedSpecs.ramValue %>" aria-label="記憶體 GB"><span>GB</span></label>
                <label class="unit-input"><input type="number" name="storage" min="1" value="<%= product.parsedSpecs.storageValue %>" aria-label="儲存空間 GB"><span>GB</span></label>
                <input type="number" name="price" min="0" value="<%= product.price %>" aria-label="價格">
                <button class="admin-action-button" type="submit">儲存</button>
              </form>
              <form method="post" action="/admin/products/<%= product.id %>/active">
                <input type="hidden" name="active" value="<%= product.active ? '0' : '1' %>">
                <button class="admin-action-button <%= product.active ? 'danger' : '' %>" type="submit"><%= product.active ? '下架' : '上架' %></button>
              </form>
              <form method="post" action="/admin/products/<%= product.id %>/delete">
                <button class="admin-action-button danger" type="submit">刪除</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (activeTab === 'nodes') { %>
      <h2>設定節點</h2>
      <% if (panelNodes.length === 0) { %>
        <div class="empty-state">目前無法從 Pterodactyl 讀取節點，請確認 Panel API token 權限。</div>
      <% } %>
      <form class="admin-table node-settings-form" method="post" action="/admin/nodes">
        <% productCategories.forEach((category, index) => { const setting = nodeSettings[category] || {}; %>
          <div class="node-setting-row">
            <strong><%= category %></strong>
            <input type="hidden" name="category_<%= index %>" value="<%= category %>">
            <select name="node_<%= index %>" class="node-select">
              <option value="">尚未設定</option>
              <% panelNodes.forEach((node) => { %>
                <option value="<%= node.id %>" data-name="<%= node.name %>" <%= Number(setting.node_id) === Number(node.id) ? 'selected' : '' %>><%= node.name %></option>
              <% }) %>
            </select>
            <input type="hidden" name="node_name_<%= index %>" value="<%= setting.node_name || '' %>">
          </div>
        <% }) %>
        <button class="button primary" type="submit">儲存節點設定</button>
      </form>
    <% } %>

    <% if (activeTab === 'users') { %>
      <h2>Store 使用者</h2>
      <div class="admin-table">
        <% users.forEach((storeUser) => { %>
          <div class="admin-row">
            <strong><%= storeUser.name %></strong>
            <span><%= storeUser.email %></span>
            <span>SQL ID #<%= storeUser.id %></span>
            <% if (storeUser.openOrderItems.length > 0) { %>
              <details class="user-open-orders">
                <summary>未處理 <%= storeUser.openOrderItems.length %> 筆</summary>
                <div>
                  <% storeUser.openOrderItems.forEach((order) => { %>
                    <a href="/orders/<%= order.id %>">
                      <strong><%= order.order_name %></strong>
                      <span><%= statusLabels[order.status] || order.status %> / NT$ <%= order.amount %></span>
                    </a>
                  <% }) %>
                </div>
              </details>
            <% } else { %>
              <em>無未處理訂單</em>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<script>
  document.addEventListener("submit", async (event) => {
    const form = event.target.closest(".admin-content form");
    if (!form) return;
    event.preventDefault();
    const submitButton = event.submitter || form.querySelector("button[type='submit']");
    const selectedProductCategory = document.querySelector(".product-category-filter")?.value || "";
    syncNodeNames();
    if (submitButton) submitButton.disabled = true;
    try {
      const response = await fetch(form.action, {
        method: form.method || "POST",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded",
          "X-Requested-With": "fetch"
        },
        body: new URLSearchParams(new FormData(form))
      });
      const html = await response.text();
      const doc = new DOMParser().parseFromString(html, "text/html");
      const nextContent = doc.querySelector(".admin-content");
      if (!response.ok || !nextContent) throw new Error("admin update failed");
      document.querySelector(".admin-content").replaceWith(nextContent);
      const nextProductCategory = document.querySelector(".product-category-filter");
      if (nextProductCategory && selectedProductCategory) nextProductCategory.value = selectedProductCategory;
      applyProductCategoryFilter();
      syncNodeNames();
    } catch {
      form.submit();
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  });

  const applyProductCategoryFilter = () => {
    const select = document.querySelector(".product-category-filter");
    if (!select) return;
    document.querySelectorAll(".product-admin-row[data-category]").forEach((row) => {
      row.hidden = row.getAttribute("data-category") !== select.value;
    });
  };

  const syncNodeNames = () => {
    document.querySelectorAll(".node-select").forEach((select) => {
      const hidden = select.closest(".node-setting-row")?.querySelector("input[name^='node_name_']");
      if (hidden) hidden.value = select.selectedOptions[0]?.dataset.name || "";
    });
  };

  document.addEventListener("change", (event) => {
    if (event.target.matches(".product-category-filter")) applyProductCategoryFilter();
    if (event.target.matches(".node-select")) syncNodeNames();
  });

  applyProductCategoryFilter();
  syncNodeNames();
</script>

<%- include("partials/footer") %>
