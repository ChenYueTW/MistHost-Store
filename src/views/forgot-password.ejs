<%- include("partials/header") %>

<section class="auth-shell">
  <form class="auth-card" method="post" action="/forgot-password">
    <p class="eyebrow">Account Recovery</p>
    <h1>忘記密碼</h1>
    <p class="muted-copy">輸入註冊 Email 後，系統會寄出一次性重設密碼連結。</p>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <% if (notice) { %>
      <div class="notice"><%= notice %></div>
    <% } %>
    <label>
      Email
      <input type="email" name="email" autocomplete="email" required>
    </label>
    <button class="button primary full" type="submit">重設密碼</button>
    <p class="auth-switch">想起密碼了？<a href="/login">返回登入</a></p>
  </form>
</section>

<%- include("partials/footer") %>
