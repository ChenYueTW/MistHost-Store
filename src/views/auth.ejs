<%- include("partials/header") %>

<section class="auth-shell">
  <form class="auth-card" method="post" action="<%= mode === 'register' ? '/register' : '/login' %>">
    <p class="eyebrow">Client Area</p>
    <h1><%= mode === "register" ? "建立帳戶" : "登入帳戶" %></h1>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <% if (mode === "register") { %>
      <label>
        姓名
        <input name="name" autocomplete="name" required>
      </label>
    <% } %>
    <label>
      Email
      <input type="email" name="email" autocomplete="email" required>
    </label>
    <label>
      密碼
      <span class="password-field">
        <input type="password" name="password" autocomplete="<%= mode === 'register' ? 'new-password' : 'current-password' %>" minlength="8" required>
        <button class="password-toggle" type="button" aria-label="顯示密碼" data-password-toggle>
          <svg class="eye-open" viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12Z"></path><path d="M12 9.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Z"></path></svg>
          <svg class="eye-closed" viewBox="0 0 24 24" aria-hidden="true" hidden style="display: none;"><path d="M3 3l18 18"></path><path d="M10.6 5.2A11.8 11.8 0 0 1 12 5c6 0 10 7 10 7a17.9 17.9 0 0 1-3.1 4.1"></path><path d="M6.4 6.7A18.4 18.4 0 0 0 2 12s4 7 10 7c1.8 0 3.4-.5 4.7-1.2"></path><path d="M9.9 9.9a2.5 2.5 0 0 0 3.2 3.2"></path></svg>
        </button>
      </span>
    </label>
    <button class="button primary full" type="submit"><%= mode === "register" ? "註冊並同步 Panel" : "登入" %></button>
    <% if (mode === "login") { %>
      <a class="forgot-link" href="/forgot-password">忘記密碼？</a>
    <% } %>

    <div class="oauth-divider"><span>或使用</span></div>
    <div class="oauth-grid">
      <a class="button ghost full oauth-button" href="/auth/google"><img class="oauth-logo" src="https://cdn.simpleicons.org/google" alt="">Google</a>
      <a class="button ghost full oauth-button" href="/auth/discord"><img class="oauth-logo" src="https://cdn.simpleicons.org/discord/5865F2" alt="">Discord</a>
    </div>

    <% if (mode === "register") { %>
      <p class="auth-switch">已經有帳戶？<a href="/login">登入</a></p>
    <% } else { %>
      <p class="auth-switch">還沒有帳戶？<a href="/register">註冊</a></p>
    <% } %>
  </form>
</section>

<script>
  document.querySelectorAll("[data-password-toggle]").forEach((button) => {
    button.addEventListener("click", () => {
      const input = button.closest(".password-field")?.querySelector("input");
      if (!input) return;
      const visible = input.type === "text";
      const openIcon = button.querySelector(".eye-open");
      const closedIcon = button.querySelector(".eye-closed");
      input.type = visible ? "password" : "text";
      button.classList.toggle("is-visible", !visible);
      openIcon?.toggleAttribute("hidden", !visible);
      closedIcon?.toggleAttribute("hidden", visible);
      if (openIcon) openIcon.style.display = visible ? "" : "none";
      if (closedIcon) closedIcon.style.display = visible ? "none" : "";
      button.setAttribute("aria-label", visible ? "顯示密碼" : "隱藏密碼");
    });
  });
</script>

<%- include("partials/footer") %>
