<%- include("partials/header") %>

<section class="account-shell">
  <aside class="account-sidebar">
    <p class="eyebrow">Account</p>
    <h1>會員中心</h1>
    <a href="/account?tab=orders">我的訂單</a>
    <a href="/account?tab=profile">個人資料</a>
    <a class="active" href="/account?tab=servers">我的伺服器</a>
  </aside>

  <section class="account-content">
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <% if (notice) { %>
      <div class="notice"><%= notice %></div>
    <% } %>

    <form class="server-detail-panel" method="post" action="/account/servers/<%= server.id %>">
      <div class="server-detail-main">
        <a class="button primary server-console-button" href="<%= server.panelUrl %>" target="_blank" rel="noreferrer">前往控制台</a>
        <h2><%= server.name %></h2>
        <label>
          伺服器名稱
          <input name="name" value="<%= server.name %>" maxlength="80" required>
        </label>

        <label>
          伺服器類型
          <select name="minecraftEggId" <%= minecraftEggs.length === 0 ? 'disabled' : '' %>>
            <% minecraftEggs.forEach((egg) => { %>
              <option value="<%= egg.id %>" <%= Number(server.egg_id) === Number(egg.id) ? 'selected' : '' %>><%= egg.name %></option>
            <% }) %>
          </select>
        </label>
        <button class="button ghost server-save-button" type="submit">儲存設定</button>
      </div>
      <aside class="server-detail-status">
        <div class="server-mini-icon <%= server.runtimeClass || 'syncing' %>" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <strong><%= server.runtimeLabel || server.statusLabel %></strong>
      </aside>
    </form>
  </section>
</section>

<%- include("partials/footer") %>
